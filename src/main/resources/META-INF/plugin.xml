<idea-plugin>
    <id>com.sonarpromptstudio</id>
    <name>Sonar Prompt Studio</name>
    <vendor email="mohamed.lachgar@gmail.com" url="https://github.com/mlachgar">Mohamed LACHGAR</vendor>
    <description><![CDATA[
        <p>Sonar Prompt Studio brings SonarQube findings review and remediation prompt generation directly into IntelliJ IDEA.</p>

        <p>Use it to connect to SonarQube Cloud or a self-hosted SonarQube Server instance, inspect issues in the IDE, and generate remediation prompts tailored for coding assistants such as Codex, Claude Code, and Qwen Code.</p>

        <h3>Features</h3>
        <ul>
            <li>Connect to SonarQube Cloud and SonarQube Server with reusable profiles</li>
            <li>Discover Sonar project settings from common repository files</li>
            <li>Review findings inside IntelliJ IDEA</li>
            <li>Generate and copy remediation prompts for supported coding assistants</li>
            <li>Refresh findings and manage plugin state from the Tools menu</li>
        </ul>

        <h3>Getting Started</h3>
        <ol>
            <li>Open <b>Settings | Tools | Sonar Prompt Studio</b> and configure a connection profile.</li>
            <li>Open your project and let the plugin discover the Sonar project configuration.</li>
            <li>Open the <b>Sonar Prompt Studio</b> tool window to review findings and generate prompts.</li>
        </ol>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Sonar Prompt Studio" displayType="BALLOON" isLogByDefault="true"/>
        <applicationService serviceImplementation="com.sonarpromptstudio.service.SonarSettingsService"/>
        <applicationService serviceImplementation="com.sonarpromptstudio.service.SecureTokenService"/>
        <projectService serviceImplementation="com.sonarpromptstudio.service.DiscoveredProjectService"/>
        <projectService serviceImplementation="com.sonarpromptstudio.service.FindingsService"/>
        <projectService serviceImplementation="com.sonarpromptstudio.service.WorkspaceStateService"/>
        <projectService serviceImplementation="com.sonarpromptstudio.service.UiRefreshService"/>

        <toolWindow id="Sonar Prompt Studio"
                    anchor="bottom"
                    factoryClass="com.sonarpromptstudio.ui.WorkspaceToolWindowFactory"
                    icon="/icons/sonarPromptStudio.svg"/>

        <postStartupActivity implementation="com.sonarpromptstudio.startup.SonarStartupActivity"/>
        <projectActivity implementation="com.sonarpromptstudio.startup.SonarProjectActivity"/>

        <applicationConfigurable instance="com.sonarpromptstudio.ui.SonarSettingsConfigurable"
                                 displayName="Sonar Prompt Studio"
                                 id="com.sonarpromptstudio.settings"/>
    </extensions>

    <actions>
        <action id="SonarPromptStudio.OpenConfiguration"
                class="com.sonarpromptstudio.actions.OpenConfigurationAction"
                text="Open Sonar Prompt Studio Configuration"/>
        <action id="SonarPromptStudio.OpenWorkspace"
                class="com.sonarpromptstudio.actions.OpenWorkspaceAction"
                text="Open Sonar Prompt Studio"/>
        <action id="SonarPromptStudio.ResetConnectionsAndProjects"
                class="com.sonarpromptstudio.actions.ResetConnectionsAndProjectsAction"
                text="Reset Connections And Projects"/>
        <action id="SonarPromptStudio.RefreshFindings"
                class="com.sonarpromptstudio.actions.RefreshFindingsAction"
                text="Refresh Findings"/>
        <action id="SonarPromptStudio.GeneratePrompt"
                class="com.sonarpromptstudio.actions.GeneratePromptAction"
                text="Generate Prompt"/>
        <action id="SonarPromptStudio.RegeneratePrompt"
                class="com.sonarpromptstudio.actions.RegeneratePromptAction"
                text="Re-Generate Prompt"/>
        <action id="SonarPromptStudio.CopyPrompt"
                class="com.sonarpromptstudio.actions.CopyPromptAction"
                text="Copy Prompt"/>

        <group id="SonarPromptStudio.Group" text="Sonar Prompt Studio" popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <reference ref="SonarPromptStudio.OpenWorkspace"/>
            <reference ref="SonarPromptStudio.RefreshFindings"/>
            <separator/>
            <reference ref="SonarPromptStudio.OpenConfiguration"/>
            <reference ref="SonarPromptStudio.ResetConnectionsAndProjects"/>
        </group>
    </actions>
</idea-plugin>
